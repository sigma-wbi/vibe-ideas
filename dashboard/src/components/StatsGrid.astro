---
interface Props {
  totalDocs: number;
  totalSections: number;
  avgProgress: number;
}

const { totalDocs, totalSections, avgProgress } = Astro.props;
---

<div class="grid grid-cols-3 gap-4">
  <div class="rounded-lg p-4 text-center" style="background: var(--bg-card); border: 1px solid var(--border);">
    <p class="text-2xl font-bold" style="color: var(--accent);">{totalDocs}</p>
    <p class="text-xs" style="color: var(--text-secondary);">총 문서</p>
  </div>
  <div class="rounded-lg p-4 text-center" style="background: var(--bg-card); border: 1px solid var(--border);">
    <p class="text-2xl font-bold" style="color: var(--accent);">{totalSections}</p>
    <p class="text-xs" style="color: var(--text-secondary);">섹션</p>
  </div>
  <div class="rounded-lg p-4 text-center" style="background: var(--bg-card); border: 1px solid var(--border);">
    <p class="text-2xl font-bold" style="color: var(--accent);">{avgProgress}%</p>
    <p class="text-xs" style="color: var(--text-secondary);">평균 진행률</p>
  </div>
</div>
