{
  "mcpServers": {
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "note": "[필수] 복잡한 추론 시 단계적 사고 지원."
    },

    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "note": "[필수] 라이브러리/프레임워크 최신 문서 조회."
    },

    "serena": {
      "command": "uvx",
      "args": [
        "--from", "git+https://github.com/oraios/serena",
        "serena-mcp-server",
        "--context", "ide-assistant",
        "--project", "."
      ],
      "note": "[필수] 코드 구조 분석 (심볼, 참조, 리네이밍)."
    }
  },

  "_disabled": {
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "note": "[선택] E2E 테스트 / 브라우저 자동화. 필요 시 mcpServers로 이동."
    }
  }
}
